  <transform>
    <name>Link Linha-Palavra</name>
    <type>ExecSql</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <arguments>
      <argument>
        <name>titulo</name>
      </argument>
      <argument>
        <name>grupo_id</name>
      </argument>
      <argument>
        <name>palavra_chave_split</name>
