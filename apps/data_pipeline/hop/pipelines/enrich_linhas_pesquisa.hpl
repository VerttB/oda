    <connection>oda_db</connection>
    <execute_each_row>Y</execute_each_row>
    <quoteString>N</quoteString>
    <replace_variables>N</replace_variables>
    <set_params>N</set_params>
    <single_statement>N</single_statement>
    <sql>
      INSERT INTO linha_pesquisa_palavra_chave (linha_pesquisa_id, palavra_chave_id)
      SELECT lp.id, pc.id
      FROM linha_pesquisa lp, palavra_chave pc
      WHERE lp.titulo = ? AND lp.grupo_id = ? AND pc.termo_normalizado = ?
      ON CONFLICT DO NOTHING;
    </sql>
    <attributes/>
    <GUI>
      <xloc>1312</xloc>
      <yloc>48</yloc>
    </GUI>
