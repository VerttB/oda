<?xml version='1.0' encoding='UTF-8'?>
<pipeline>
  <info>
    <name>clean_researchers_data</name>
    <description />
    <extended_description />
    <pipeline_version />
    <pipeline_type>Normal</pipeline_type>
  </info>
  <order>
    <hop>
      <from>Ler Staging Pesquisadores</from>
      <to>Lookup Grupo ID</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Lookup Grupo ID</from>
      <to>Tratar Enums e Nulls</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Tratar Enums e Nulls</from>
      <to>Inserir/Atualizar Pesquisador</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Inserir/Atualizar Pesquisador</from>
      <to>Link Membro Grupo</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Link Membro Grupo</from>
      <to>Link Areas Atuacao</to>
      <enabled>Y</enabled>
    </hop>
  </order>

  <transform>
    <name>Ler Staging Pesquisadores</name>
    <type>TableInput</type>
    <copies>1</copies><connection>oda_db</connection>
    <sql>SELECT dgp_id, nome, lattes_id, formacao, categoria, areas_atuacao FROM stg_pesquisador</sql>
    <GUI>
      <xloc>100</xloc>
      <yloc>100</yloc>
    </GUI>
  </transform>

  <transform>
    <name>Lookup Grupo ID</name>
    <type>DBLookup</type>
    <copies>1</copies><connection>oda_db</connection>
    <lookup>
      <table>grupo_pesquisa</table>
      <key>
        <name>dgp_id</name>
        <field>dgp_id</field>
        <condition>=</condition>
      </key>
      <value>
        <name>id</name>
        <rename>grupo_id</rename>
        <default />
        <type>String</type>
      </value>
    </lookup>
    <GUI>
      <xloc>300</xloc>
      <yloc>100</yloc>
    </GUI>
  </transform>

  <transform>
    <name>Tratar Enums e Nulls</name>
    <type>StringOperations</type>
    <copies>1</copies><fields>
      <field>
        <in_stream_name>formacao</in_stream_name>
        <trim_type>both</trim_type>
        <lower_upper>lower</lower_upper>
      </field>
      <field>
        <in_stream_name>categoria</in_stream_name>
        <trim_type>both</trim_type>
        <lower_upper>lower</lower_upper>
      </field>
    </fields>
    <GUI>
      <xloc>500</xloc>
      <yloc>100</yloc>
    </GUI>
  </transform>

  <transform>
    <name>Inserir/Atualizar Pesquisador</name>
    <type>InsertUpdate</type>
    <copies>1</copies><connection>oda_db</connection>
    <commit>100</commit>
    <lookup>
      <table>pesquisador</table>
      <key>
        <name>nome</name>
        <field>nome</field>
        <condition>=</condition>
      </key>
      <value>
        <name>nome</name>
        <rename>nome</rename>
        <update>Y</update>
      </value>
      <value>
        <name>lattes_id</name>
        <rename>lattes_id</rename>
        <update>Y</update>
      </value>
    </lookup>
    <GUI>
      <xloc>700</xloc>
      <yloc>100</yloc>
    </GUI>
  </transform>

  <transform>
    <name>Link Membro Grupo</name>
    <type>ExecSQL</type>
    <copies>1</copies><connection>oda_db</connection>
    <execute_each_row>Y</execute_each_row>
    <sql>
      INSERT INTO membro_grupo (pesquisador_id, grupo_id)
      SELECT p.id, ?
      FROM pesquisador p
      WHERE p.nome = ?
      ON CONFLICT DO NOTHING;
    </sql>
    <arguments>
      <argument>
        <name>grupo_id</name>
      </argument>
      <argument>
        <name>nome</name>
      </argument>
    </arguments>
    <GUI>
      <xloc>900</xloc>
      <yloc>100</yloc>
    </GUI>
  </transform>

  <transform>
    <name>Link Areas Atuacao</name>
    <type>ExecSQL</type>
    <copies>1</copies><connection>oda_db</connection>
    <execute_each_row>Y</execute_each_row>
    <sql>
      WITH input_data AS (
        SELECT ?::text AS areas_json, ?::text AS p_nome
      ),
      parsed_areas AS (
        SELECT json_array_elements_text(NULLIF(areas_json, '')::json) AS area_nome
        FROM input_data
        WHERE areas_json IS NOT NULL AND areas_json != '' AND areas_json != '[]'
      ),
      upserted_areas AS (
        INSERT INTO area_atuacao (id, nome, nome_normalizado, criado_em, atualizado_em)
        SELECT gen_random_uuid(), area_nome, lower(area_nome), now(), now()
        FROM parsed_areas
        ON CONFLICT (nome) DO NOTHING
        RETURNING id, nome
      ),
      all_areas AS (
        SELECT id, nome FROM upserted_areas
        UNION ALL
        SELECT a.id, a.nome FROM area_atuacao a
        JOIN parsed_areas pa ON a.nome = pa.area_nome
      )
      INSERT INTO pesquisador_area_atuacao (pesquisador_id, area_atuacao_id, criado_em)
      SELECT p.id, aa.id, now()
      FROM pesquisador p
      CROSS JOIN all_areas aa
      WHERE p.nome = (SELECT p_nome FROM input_data)
      ON CONFLICT DO NOTHING;
    </sql>
    <arguments>
      <argument>
        <name>areas_atuacao</name>
      </argument>
      <argument>
        <name>nome</name>
      </argument>
    </arguments>
    <GUI>
      <xloc>1100</xloc>
      <yloc>100</yloc>
    </GUI>
  </transform>
</pipeline>