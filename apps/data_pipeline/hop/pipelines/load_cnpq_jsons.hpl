<?xml version="1.0" encoding="UTF-8"?>
<pipeline>
  <info>
    <name>load_cnpq_jsons</name>
    <name_sync_with_filename>Y</name_sync_with_filename>
    <description/>
    <extended_description/>
    <pipeline_version/>
    <pipeline_type>Normal</pipeline_type>
    <parameters/>
    <capture_transform_performance>N</capture_transform_performance>
    <transform_performance_capturing_delay>1000</transform_performance_capturing_delay>
    <transform_performance_capturing_size_limit>100</transform_performance_capturing_size_limit>
    <created_user>-</created_user>
    <created_date>2024/01/01 00:00:00.000</created_date>
    <modified_user>-</modified_user>
    <modified_date>2024/01/01 00:00:00.000</modified_date>
  </info>
  <notepads>
    <notepad>
      <note>ETL inicial: 
1. Listar arquivos JSON
2. Extrair dados de Grupos e Pesquisadores
3. Salvar em tabelas de staging</note>
      <xloc>64</xloc>
      <yloc>48</yloc>
      <width>250</width>
      <height>70</height>
    </notepad>
  </notepads>
  <order>
    <hop>
      <from>Pegar JSONs</from>
      <to>Extrair Grupos JSON</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Extrair Grupos JSON</from>
      <to>Staging Grupo Pesquisa</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Pegar JSONs</from>
      <to>Extrair Pesquisadores JSON</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Extrair Pesquisadores JSON</from>
      <to>Staging Pesquisadores</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Pegar JSONs</from>
      <to>Extrair Linhas JSON</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Extrair Linhas JSON</from>
      <to>Staging Linhas</to>
      <enabled>Y</enabled>
    </hop>
  </order>
  <transform>
    <name>Pegar JSONs</name>
    <type>GetFileNames</type>
    <description/>
    <distribute>N</distribute>
    <copies>1</copies>
    <file>
      <name>${PROJECT_HOME}/data/dgp</name>
      <filemask>.*\.json</filemask>
      <exclude_filemask/>
      <file_required>N</file_required>
      <include_subfolders>N</include_subfolders>
    </file>
    <GUI>
      <xloc>100</xloc>
      <yloc>200</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Extrair Grupos JSON</name>
    <type>JsonInput</type>
    <description/>
    <distribute>Y</distribute>
    <copies>1</copies>
    <include>N</include>
    <include_field/>
    <rownum>N</rownum>
    <addresultfile>N</addresultfile>
    <readurl>N</readurl>
    <removeSourceField>N</removeSourceField>
    <IsIgnoreEmptyFile>N</IsIgnoreEmptyFile>
    <doNotFailIfNoFile>Y</doNotFailIfNoFile>
    <ignoreMissingPath>Y</ignoreMissingPath>
    <defaultPathLeafToNull>Y</defaultPathLeafToNull>
    <includeNulls>N</includeNulls>
    <rownum_field/>
    <file>
      <name/>
      <filemask/>
      <exclude_filemask/>
      <file_required>N</file_required>
      <include_subfolders>N</include_subfolders>
    </file>
    <fields>
      <field>
        <name>nome_grupo</name>
        <path>$.nome</path>
        <type>String</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <length>-1</length>
        <precision>-1</precision>
        <trim_type>none</trim_type>
        <repeat>N</repeat>
      </field>
      <field>
        <name>dgp_id</name>
        <path>$.id_dgp</path>
        <type>String</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <length>-1</length>
        <precision>-1</precision>
        <trim_type>none</trim_type>
        <repeat>N</repeat>
      </field>
      <field>
        <name>repercussao</name>
        <path>$.repercussao</path>
        <type>String</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <length>-1</length>
        <precision>-1</precision>
        <trim_type>none</trim_type>
        <repeat>N</repeat>
      </field>
      <field>
        <name>area_predominante</name>
        <path>$.area</path>
        <type>String</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <length>-1</length>
        <precision>-1</precision>
        <trim_type>none</trim_type>
        <repeat>N</repeat>
      </field>
      <field>
        <name>instituicao</name>
        <path>$.instituicao</path>
        <type>String</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <length>-1</length>
        <precision>-1</precision>
        <trim_type>none</trim_type>
        <repeat>N</repeat>
      </field>
      <field>
        <name>ano_formacao</name>
        <path>$.ano_formacao</path>
        <type>Integer</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <length>-1</length>
        <precision>-1</precision>
        <trim_type>none</trim_type>
        <repeat>N</repeat>
      </field>
      <field>
        <name>uf</name>
        <path>$.endereco.uf</path>
        <type>String</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <length>-1</length>
        <precision>-1</precision>
        <trim_type>none</trim_type>
        <repeat>N</repeat>
      </field>
    </fields>
    <limit>0</limit>
    <IsInFields>Y</IsInFields>
    <IsAFile>Y</IsAFile>
    <valueField>filename</valueField>
    <shortFileFieldName/>
    <pathFieldName/>
    <hiddenFieldName/>
    <lastModificationTimeFieldName/>
    <uriNameFieldName/>
    <rootUriNameFieldName/>
    <extensionFieldName/>
    <sizeFieldName/>
    <GUI>
      <xloc>300</xloc>
      <yloc>150</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Staging Grupo Pesquisa</name>
    <type>TableOutput</type>
    <description/>
    <distribute>Y</distribute>
    <copies>1</copies>
    <connection>oda_db</connection>
    <schema/>
    <table>stg_grupo_pesquisa</table>
    <commit>1000</commit>
    <truncate>Y</truncate>
    <ignore_errors>N</ignore_errors>
    <use_batch>Y</use_batch>
    <specify_fields>Y</specify_fields>
    <partitioning_enabled>N</partitioning_enabled>
    <fields>
      <field>
        <column_name>nome</column_name>
        <stream_name>nome_grupo</stream_name>
      </field>
      <field>
        <column_name>dgp_id</column_name>
        <stream_name>dgp_id</stream_name>
      </field>
      <field>
        <column_name>repercussao</column_name>
        <stream_name>repercussao</stream_name>
      </field>
      <field>
        <column_name>area_predominante</column_name>
        <stream_name>area_predominante</stream_name>
      </field>
      <field>
        <column_name>instituicao_nome</column_name>
        <stream_name>instituicao</stream_name>
      </field>
      <field>
        <column_name>ano_formacao</column_name>
        <stream_name>ano_formacao</stream_name>
      </field>
      <field>
        <column_name>uf</column_name>
        <stream_name>uf</stream_name>
      </field>
    </fields>
    <GUI>
      <xloc>500</xloc>
      <yloc>150</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Extrair Pesquisadores JSON</name>
    <type>JsonInput</type>
    <description/>
    <distribute>Y</distribute>
    <copies>1</copies>
    <include>N</include>
    <include_field/>
    <rownum>N</rownum>
    <addresultfile>N</addresultfile>
    <readurl>N</readurl>
    <removeSourceField>N</removeSourceField>
    <IsIgnoreEmptyFile>N</IsIgnoreEmptyFile>
    <doNotFailIfNoFile>Y</doNotFailIfNoFile>
    <ignoreMissingPath>Y</ignoreMissingPath>
    <defaultPathLeafToNull>Y</defaultPathLeafToNull>
    <includeNulls>N</includeNulls>
    <rownum_field/>
    <file>
      <name/>
      <filemask/>
      <exclude_filemask/>
      <file_required>N</file_required>
      <include_subfolders>N</include_subfolders>
    </file>
    <fields>
      <field>
        <name>nome_pesquisador</name>
        <path>$.membros[*].nome</path>
        <type>String</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <length>-1</length>
        <precision>-1</precision>
        <trim_type>none</trim_type>
        <repeat>N</repeat>
      </field>
      <field>
        <name>lattes_id</name>
        <path>$.membros[*].lattes</path>
        <type>String</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <length>-1</length>
        <precision>-1</precision>
        <trim_type>none</trim_type>
        <repeat>N</repeat>
      </field>
      <field>
        <name>formacao</name>
        <path>$.membros[*].formacao_academica</path>
        <type>String</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <length>-1</length>
        <precision>-1</precision>
        <trim_type>none</trim_type>
        <repeat>N</repeat>
      </field>
      <field>
        <name>categoria</name>
        <path>$.membros[*].categoria_lattes</path>
        <type>String</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <length>-1</length>
        <precision>-1</precision>
        <trim_type>none</trim_type>
        <repeat>N</repeat>
      </field>
      <field>
        <name>dgp_id</name>
        <path>$.id_dgp</path>
        <type>String</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <length>-1</length>
        <precision>-1</precision>
        <trim_type>none</trim_type>
        <repeat>N</repeat>
      </field>
      <field>
        <name>areas_atuacao</name>
        <path>$.membros[*].areas</path>
        <type>String</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <length>-1</length>
        <precision>-1</precision>
        <trim_type>none</trim_type>
        <repeat>N</repeat>
      </field>
    </fields>
    <limit>0</limit>
    <IsInFields>Y</IsInFields>
    <IsAFile>Y</IsAFile>
    <valueField>filename</valueField>
    <shortFileFieldName/>
    <pathFieldName/>
    <hiddenFieldName/>
    <lastModificationTimeFieldName/>
    <uriNameFieldName/>
    <rootUriNameFieldName/>
    <extensionFieldName/>
    <sizeFieldName/>
    <GUI>
      <xloc>300</xloc>
      <yloc>250</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Staging Pesquisadores</name>
    <type>TableOutput</type>
    <description/>
    <distribute>Y</distribute>
    <copies>1</copies>
    <connection>oda_db</connection>
    <schema/>
    <table>stg_pesquisador</table>
    <commit>1000</commit>
    <truncate>Y</truncate>
    <ignore_errors>N</ignore_errors>
    <use_batch>Y</use_batch>
    <specify_fields>Y</specify_fields>
    <partitioning_enabled>N</partitioning_enabled>
    <fields>
      <field>
        <column_name>nome</column_name>
        <stream_name>nome_pesquisador</stream_name>
      </field>
      <field>
        <column_name>lattes_id</column_name>
        <stream_name>lattes_id</stream_name>
      </field>
      <field>
        <column_name>formacao</column_name>
        <stream_name>formacao</stream_name>
      </field>
      <field>
        <column_name>categoria</column_name>
        <stream_name>categoria</stream_name>
      </field>
      <field>
        <column_name>dgp_id</column_name>
        <stream_name>dgp_id</stream_name>
      </field>
      <field>
        <column_name>areas_atuacao</column_name>
        <stream_name>areas_atuacao</stream_name>
      </field>
    </fields>
    <GUI>
      <xloc>500</xloc>
      <yloc>250</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Extrair Linhas JSON</name>
    <type>JsonInput</type>
    <description/>
    <distribute>Y</distribute>
    <copies>1</copies>
    <include>N</include>
    <include_field/>
    <rownum>N</rownum>
    <addresultfile>N</addresultfile>
    <readurl>N</readurl>
    <removeSourceField>N</removeSourceField>
    <IsIgnoreEmptyFile>N</IsIgnoreEmptyFile>
    <doNotFailIfNoFile>Y</doNotFailIfNoFile>
    <ignoreMissingPath>Y</ignoreMissingPath>
    <defaultPathLeafToNull>Y</defaultPathLeafToNull>
    <includeNulls>N</includeNulls>
    <rownum_field/>
    <file>
      <name/>
      <filemask/>
      <exclude_filemask/>
      <file_required>N</file_required>
      <include_subfolders>N</include_subfolders>
    </file>
    <fields>
      <field>
        <name>dgp_id</name>
        <path>$.id_dgp</path>
        <type>String</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <length>-1</length>
        <precision>-1</precision>
        <trim_type>none</trim_type>
        <repeat>N</repeat>
      </field>
      <field>
        <name>titulo</name>
        <path>$.linhas[*].nome</path>
        <type>String</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <length>-1</length>
        <precision>-1</precision>
        <trim_type>none</trim_type>
        <repeat>N</repeat>
      </field>
      <field>
        <name>objetivo</name>
        <path>$.linhas[*].objetivo</path>
        <type>String</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <length>-1</length>
        <precision>-1</precision>
        <trim_type>none</trim_type>
        <repeat>N</repeat>
      </field>
      <field>
        <name>setor_aplicacao</name>
        <path>$.linhas[*].setores_aplicacao</path>
        <type>String</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <length>-1</length>
        <precision>-1</precision>
        <trim_type>none</trim_type>
        <repeat>N</repeat>
      </field>
      <field>
        <name>palavra_chave</name>
        <path>$.linhas[*].palavras_chave</path>
        <type>String</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <length>-1</length>
        <precision>-1</precision>
        <trim_type>none</trim_type>
        <repeat>N</repeat>
      </field>
    </fields>
    <limit>0</limit>
    <IsInFields>Y</IsInFields>
    <IsAFile>Y</IsAFile>
    <valueField>filename</valueField>
    <shortFileFieldName/>
    <pathFieldName/>
    <hiddenFieldName/>
    <lastModificationTimeFieldName/>
    <uriNameFieldName/>
    <rootUriNameFieldName/>
    <extensionFieldName/>
    <sizeFieldName/>
    <GUI>
      <xloc>300</xloc>
      <yloc>350</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Staging Linhas</name>
    <type>TableOutput</type>
    <description/>
    <distribute>Y</distribute>
    <copies>1</copies>
    <connection>oda_db</connection>
    <schema/>
    <table>stg_linha_pesquisa</table>
    <commit>1000</commit>
    <truncate>Y</truncate>
    <ignore_errors>N</ignore_errors>
    <use_batch>Y</use_batch>
    <specify_fields>Y</specify_fields>
    <partitioning_enabled>N</partitioning_enabled>
    <fields>
      <field>
        <column_name>dgp_id</column_name>
        <stream_name>dgp_id</stream_name>
      </field>
      <field>
        <column_name>titulo</column_name>
        <stream_name>titulo</stream_name>
      </field>
      <field>
        <column_name>objetivo</column_name>
        <stream_name>objetivo</stream_name>
      </field>
      <field>
        <column_name>setor_aplicacao</column_name>
        <stream_name>setor_aplicacao</stream_name>
      </field>
      <field>
        <column_name>palavra_chave</column_name>
        <stream_name>palavra_chave</stream_name>
      </field>
    </fields>
    <GUI>
      <xloc>500</xloc>
      <yloc>350</yloc>
    </GUI>
  </transform>
</pipeline>
